            "default_values": "search_default_values.date"
          }
        }
      },
      "Encounter": {
        "search_param": {
          "clinical-date": {
            "multiple_and_expectation": "SHOULD",
            "comparators": "search.comparators",
            "default_values": "search_default_values.date"
          },
