          "test_type": "search"
        },
        {
          "path_to_generator": "lib/au_core_test_kit/generators/custom_identifier_chain_search/generator.rb",
          "generator_class": "InfernoSuiteGenerator::Generator::SpecialIdentifiersChainSearchTestGenerator",
          "path_to_template": "",
          "test_type": "search"
        },
        {
          "path_to_generator": "lib/au_core_test_kit/generators/medication_inclusion_test/generator.rb",
          "generator_class": "InfernoSuiteGenerator::Generator::MedicationInclusionTestGenerator",
          "path_to_template": "",
          "test_type": "validation"
        }
      ]
    },
    "profiles": {
      "http://hl7.org.au/fhir/core/StructureDefinition/au-core-bloodpressure": {
        "exclude_elements_from_must_support": ["value[x]", "Observation.value[x]:valueQuantity", "dataAbsentReason"]
      },
      "http://hl7.org.au/fhir/core/StructureDefinition/au-core-heartrate": {
        "exclude_elements_from_must_support": ["component", "component.code", "component.value[x]", "component.dataAbsentReason", "dataAbsentReason"]
      },
      "http://hl7.org.au/fhir/core/StructureDefinition/au-core-location": {
        "first_class_profile": "read"
      },
      "http://hl7.org.au/fhir/StructureDefinition/au-specimen": {
        "skip": true
      },
      "http://hl7.org.au/fhir/StructureDefinition/au-imagingresult": {
        "skip": true
      },
      "http://hl7.org.au/fhir/core/StructureDefinition/au-core-diagnosticresult-path": {
        "fixed_values_to_search": [],
        "forced_initial_search": ["patient", "category"],
        "exclude_elements_from_must_support": ["component.dataAbsentReason", "dataAbsentReason"] 
      },
      "http://hl7.org.au/fhir/core/StructureDefinition/au-core-diagnosticresult": {
        "exclude_elements_from_must_support": ["component.dataAbsentReason", "dataAbsentReason"], 
        "search_param": {
          "clinical-code": {
            "default_values": "search_default_values.diagnostic_result"
          }
        }
      }
    },
    "resources": {
