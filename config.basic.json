          {
            "names": ["patient", "intent", "status"],
            "type": "include",
            "param": "MedicationRequest:medication",
            "target_resource": "Medication",
            "paths": ["medicationReference"]
          },
          {
            "names": ["patient", "intent", "authoredon"],
            "type": "include",
            "param": "MedicationRequest:medication",
            "target_resource": "Medication",
            "paths": ["medicationReference"]
          }
        ]
      },
      "Procedure": {
        "search_param": {
