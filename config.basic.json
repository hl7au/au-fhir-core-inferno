            "paths": ["practitioner"]
          },
          {
            "names": ["identifier"],
            "type": "include",
            "param": "PractitionerRole:practitioner",
            "target_resource": "Practitioner",
            "paths": ["practitioner"]
          },
          {
            "names": ["practitioner"],
            "type": "include",
            "param": "PractitionerRole:practitioner",
            "target_resource": "Practitioner",
            "paths": ["practitioner"]
          },
          {
